    "deploy-commands": "deno run --allow-all ./utils/deploy.ts",
    "delete-commands": "deno run --allow-all ./utils/delete.ts"
  },
  "imports": {
    "@/": "./",
    "@coven/terminal": "jsr:@coven/terminal@^0.8.5",
    "@repositories": "./repositories/index.ts",
    "@services": "./services/index.ts",
    "@logging": "./utils/logging.ts",
    "@discordjs/voice": "npm:@discordjs/voice@^0.19.2",
    "@snazzah/davey": "npm:@snazzah/davey@^0.1.11",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/async": "jsr:@std/async@^1.4.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@types/pg": "npm:@types/pg@^8.20.0",
    "bufferutil": "npm:bufferutil@^4.1.0",
    "discord.js": "npm:discord.js@^14.26.4",
    "ffmpeg-static": "npm:ffmpeg-static@^5.3.0",
    "pg": "npm:pg@^8.21.0",
    "sodium": "npm:sodium@^3.0.2",
